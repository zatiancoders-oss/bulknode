# Bulk Node Backend Configurations

PORT=3000

# Supabase Credentials (Optional - Leave blank to use local db.json database)
SUPABASE_URL=
SUPABASE_KEY=

# Pterodactyl Panel Integration
PTERODACTYL_URL=https://clients.bulknodes.xyz
PTERODACTYL_APP_KEY=your_application_api_key
PTERODACTYL_CLIENT_KEY=your_client_api_key

# Zenuxs Payments Configuration
ZENUXS_API_KEY=your_zenuxs_api_key
ZENUXS_API_SECRET=your_zenuxs_api_secret
ZENUXS_WEBHOOK_SECRET=your_zenuxs_webhook_secret
